<view class="page home-page">
  <view class="topbar">
    <view class="brand">
      <text class="iconfont brand-icon">{{icons.dice}}</text>
      <view class="brand-name">一局一分</view>
    </view>
  </view>

  <view class="greeting">
    <view>
      <view class="hello">你好，{{userName}}</view>
      <view class="hello-copy">准备好和家人们来一场愉快的博弈了吗？</view>
    </view>
    <view class="greeting-art-img">
      <image class="greeting-img" src="/images/greeting-art.jpg" mode="aspectFit"></image>
    </view>
  </view>

  <view wx:if="{{currentGame}}" class="current-card card">
    <view class="current-head">
      <view>
        <view class="game-title-row">
          <view class="live-dot animate-pulse"></view>
          <view class="game-title">{{currentGame.name}}</view>
        </view>
        <view class="game-meta">邀请码: {{currentGame.inviteCode}} · {{currentGame.participantCount}}人参与</view>
      </view>
      <view class="my-score">
        <view class="score-label">当前个人分值</view>
        <view class="score-value">{{currentGame.myScore >= 0 ? '+' : ''}}{{currentGame.myScore}}</view>
      </view>
    </view>
    <button class="button-primary enter-button" hover-class="tap-feedback" bindtap="enterGame">
      <text class="iconfont button-icon">{{icons.enter}}</text>
      进入牌局
    </button>
    <button wx:if="{{currentGame.canExit}}" class="exit-button" hover-class="tap-feedback" bindtap="exitGame">
      <text class="iconfont button-icon">{{icons.exit}}</text>
      退出牌局
    </button>
    <block wx:else>
      <button class="exit-button disabled" hover-class="tap-feedback" bindtap="showExitTip">
        <text class="iconfont button-icon">{{icons.exit}}</text>
        退出牌局
      </button>
      <view class="exit-tip">分值清零后可退出</view>
    </block>
  </view>
  <view wx:else class="current-card card empty-card" style="display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40rpx; min-height: 200rpx;">
    <view class="empty-text" style="color: var(--text-muted); font-size: 28rpx; margin-bottom: 20rpx;">当前没有进行中的牌局</view>
  </view>

  <view class="actions">
    <button wx:if="{{currentGame}}" class="create-disabled" disabled>
      <text class="iconfont button-icon">{{icons.plusCircle}}</text>
      已在牌局中
    </button>
    <button wx:else class="button-primary create-button" hover-class="tap-feedback" bindtap="createGame">
      <text class="iconfont button-icon">{{icons.plusCircle}}</text>
      创建牌局
    </button>
  </view>

  <view class="overview">
    <view class="section-title">半年概览</view>
    <view class="stat-grid">
      <view wx:for="{{stats}}" wx:key="label" class="stat-card card {{item.tone}}">
        <view class="stat-top">
          <view>{{item.label}}</view>
          <text class="iconfont stat-icon">{{item.iconCode}}</text>
        </view>
        <view class="stat-number">{{item.value}}<text>{{item.unit}}</text></view>
      </view>
    </view>
  </view>

  <view class="recent-section">
    <view class="section-head">
      <view class="section-title">最近牌局</view>
      <view class="more-btn" bindtap="history" hover-class="tap-feedback">查看全部</view>
    </view>
    <view class="recent-list">
      <view wx:for="{{recentGames}}" wx:key="title" class="recent-card card" hover-class="tap-feedback">
        <text class="iconfont recent-icon">{{item.iconCode}}</text>
        <view class="recent-main">
          <view class="recent-row">
            <view class="recent-title">{{item.title}}</view>
            <view class="recent-status">{{item.status}}</view>
          </view>
          <view class="recent-meta">{{item.meta}}</view>
        </view>
        <view class="recent-score">
          <view style="font-size: 20rpx; color: #6f7976; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 140rpx;">胜者: {{item.winnerName}}</view>
          <text style="color: #1f695d; font-size: 28rpx; font-weight: 900; display: block; margin-top: 6rpx;">{{item.winnerScoreText}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-nav">
    <button class="nav-item active">
      <text class="iconfont">{{icons.home}}</text>
      <text class="nav-label">首页</text>
    </button>
    <button class="nav-item" bindtap="goToRanking">
      <text class="iconfont">{{icons.ranking}}</text>
      <text class="nav-label">数据</text>
    </button>
    <button class="nav-item" bindtap="history">
      <text class="iconfont">{{icons.history}}</text>
      <text class="nav-label">历史</text>
    </button>
  </view>
</view>
