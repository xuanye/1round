.detail-page {
  padding-top: 20rpx;
  padding-bottom: 260rpx;
}

.detail-topbar,
.section-row,
.participant-row,
.person,
.history-head,
.transfer-card,
.bottom-nav {
  display: flex;
}

.detail-topbar {
  position: relative;
  z-index: 5;
  align-items: center;
  justify-content: space-between;
  min-height: 96rpx;
  margin: -20rpx -40rpx 28rpx;
  padding: 20rpx 40rpx;
  background: rgba(250, 249, 246, 0.86);
}

.round-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  color: #1f695d;
  background: #f4f3f1;
}

.round-button .iconfont {
  font-size: 38rpx !important;
}

.detail-title {
  min-width: 0;
  max-width: 430rpx;
  text-align: center;
}

.detail-title view {
  color: #1f695d;
  font-size: 36rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-title text {
  display: block;
  color: #3f4946;
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.section-row,
.history-head {
  align-items: center;
  justify-content: space-between;
  margin-top: 26rpx;
}

.section-label {
  color: #3f4946;
  font-size: 24rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
}

.rank-link {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1f695d;
  background: transparent;
  font-size: 26rpx;
}

.rank-link .inline-icon {
  font-size: 30rpx !important;
  margin-right: 6rpx;
}

.participant-list {
  margin-top: 18rpx;
  overflow: hidden;
}

.participant-row {
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(190, 201, 197, 0.24);
}

.participant-row:last-child {
  border-bottom: 0;
}

.person {
  align-items: center;
  flex: 1;
  min-width: 0;
}

.avatar-wrap {
  position: relative;
  margin-right: 22rpx;
}

.avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  color: #00332c;
  background: #a9f0e0;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 92rpx;
  text-align: center;
}

.participant-row:nth-child(2) .avatar {
  color: #ffffff;
  background: #29657e;
}

.participant-row:nth-child(3) .avatar {
  color: #2f1400;
  background: #ffdcc4;
}

.star-icon {
  position: absolute;
  right: -8rpx;
  bottom: -8rpx;
  width: 34rpx;
  height: 34rpx;
  border: 4rpx solid #ffffff;
  border-radius: 50%;
  color: #ffffff !important;
  background: #8e4e14;
  font-size: 20rpx !important;
  line-height: 34rpx;
  text-align: center;
  display: block;
}

.person-name {
  min-width: 0;
  color: #1a1c1a;
  font-size: 30rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.person-role,
.transfer-time {
  margin-top: 6rpx;
  color: #3f4946;
  font-size: 22rpx;
}

.score {
  flex-shrink: 0;
  margin-left: 20rpx;
  font-size: 38rpx;
  font-weight: 900;
}

.score.positive { color: #1f695d; }
.score.negative { color: #ba1a1a; }
.score.muted { color: #3f4946; }

.score-entry {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 108rpx;
  margin-top: 30rpx;
  font-size: 36rpx;
  line-height: 1;
  transition: transform 100ms ease;
}

.score-entry:active {
  transform: scale(0.96);
}

.score-entry .button-icon {
  margin-right: 12rpx;
  font-size: 40rpx !important;
}

.history-head .history-header-icon {
  color: #6f7976;
  font-size: 34rpx !important;
}

.transfer-list {
  display: flex;
  flex-direction: column;
  margin-top: 20rpx;
}

.transfer-card + .transfer-card {
  margin-top: 20rpx;
}

.transfer-card {
  align-items: flex-start;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #f4f3f1;
}

.transfer-icon {
  margin-right: 20rpx;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  color: #1f695d;
  background: rgba(31, 105, 93, 0.1);
  font-size: 36rpx !important;
  line-height: 60rpx;
  text-align: center;
  display: block;
}

.transfer-main {
  flex: 1;
  min-width: 0;
}

.transfer-text {
  color: #1a1c1a;
  font-size: 30rpx;
  line-height: 1.45;
  word-break: break-all;
}

.strong,
.transfer-score {
  font-weight: 900;
}

.transfer-score {
  color: #1f695d;
}

.bottom-actions {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 10;
}

.finish-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: auto;
  height: 88rpx;
  margin: 0 40rpx 20rpx;
  color: #ffffff;
  background: #ba1a1a;
  font-size: 28rpx;
  line-height: 1;
  box-shadow: 0 12rpx 34rpx rgba(186, 26, 26, 0.16);
  transition: transform 100ms ease;
}

.finish-button:active {
  transform: scale(0.96);
}

.finish-button .button-icon {
  margin-right: 12rpx;
  font-size: 36rpx !important;
}

.bottom-nav {
  justify-content: space-around;
  padding: 14rpx 36rpx 34rpx;
  border-radius: 32rpx 32rpx 0 0;
  background: #efeeeb;
  box-shadow: 0 -8rpx 28rpx rgba(31, 105, 93, 0.08);
}

.bottom-nav button {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 132rpx;
  height: 82rpx;
  color: #3f4946;
  background: transparent;
  font-size: 34rpx;
  line-height: 1;
}

.bottom-nav .nav-label {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.15;
}

.bottom-nav .active {
  color: #1f695d;
  background: transparent;
  font-weight: bold;
}

.bottom-nav button .iconfont {
  font-size: 44rpx !important;
  line-height: 44rpx;
}
