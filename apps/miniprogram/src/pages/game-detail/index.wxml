<view class="page detail-page">
  <!-- Topbar -->
  <view class="detail-topbar">
    <view style="width: 76rpx;"></view>
    <view class="detail-title">
      <view>{{game.name}}</view>
      <text>{{game.createdAtText}}</text>
    </view>
    <button wx:if="{{game.status === 'active'}}" class="round-button" bindtap="showInvite" hover-class="tap-feedback">
      <text class="iconfont">{{icons.qrCode}}</text>
    </button>
    <view wx:else style="width: 76rpx;"></view>
  </view>

  <!-- ACTIVE MODE UI -->
  <block wx:if="{{game.status === 'active'}}">
    <!-- Pending Finish Request Banner -->
    <view wx:if="{{pendingFinishRequest}}" class="finish-request-banner card">
      <block wx:if="{{game.isCreator}}">
        <view class="finish-banner-title">“{{pendingFinishRequest.requestedByName}}”申请结束本局</view>
        <view class="finish-banner-actions">
          <button class="finish-banner-btn approve" bindtap="approveFinish">确认结束</button>
          <button class="finish-banner-btn reject" bindtap="rejectFinish">拒绝</button>
        </view>
      </block>
      <block wx:else>
        <view class="finish-pending-text">
          <text class="iconfont inline-icon animate-pulse">{{icons.history}}</text>
          正在等待创建者确认结束（由 {{pendingFinishRequest.requestedByName}} 发起）...
        </view>
      </block>
    </view>

    <!-- Round Warning Banner -->
    <view wx:if="{{roundStatus && roundStatus.pendingPlayerNames.length > 0 && transfers.length > 0}}" class="round-warning-banner card">
      <view class="round-warning-text">
        <text class="iconfont inline-icon animate-pulse" style="margin-right: 8rpx; color: #ba1a1a;">{{icons.info}}</text>
        本轮（第{{roundStatus.roundNo}}局）还有 {{uninvolvedNamesText}} 尚未计分/被计分。
      </view>
    </view>

    <!-- Active Participants Section -->
    <view class="section-row">
      <view class="section-label">当前参与者</view>
      <view class="rank-link" bindtap="ranking" hover-class="tap-feedback">
        <text class="iconfont inline-icon">{{icons.ranking}}</text>
        排行榜
      </view>
    </view>

    <view class="participant-list card">
      <view wx:for="{{participants}}" wx:key="id" class="participant-row" bindtap="{{item.isMe ? 'renameSelf' : ''}}">
        <view class="person">
          <view class="avatar-wrap {{item.isCreator ? 'creator' : ''}}">
            <view class="avatar">{{item.initial}}</view>
            <text wx:if="{{item.isCreator}}" class="iconfont star-icon">{{icons.star}}</text>
          </view>
          <view>
            <view class="person-name">{{item.name}} {{item.isMe ? '(我)' : ''}}</view>
            <view class="person-role">{{item.role}}</view>
          </view>
        </view>
        <view class="score {{item.scoreTone}}">{{item.score}}</view>
      </view>
    </view>

    <view class="rename-tip">点击自己可修改名字 (Taps self to rename)</view>

    <!-- Start Scoring -->
    <button class="button-primary score-entry" bindtap="inputScore" hover-class="tap-feedback" disabled="{{participants.length < 2}}">
      <text class="iconfont button-icon">{{icons.plusCircle}}</text>
      开始计分
    </button>
  </block>

  <!-- SETTLED MODE UI -->
  <block wx:else>
    <view class="section-row">
      <view class="section-label" style="color: #ba1a1a;">已结算 (只读)</view>
      <view class="settled-badge" style="background: rgba(186, 26, 26, 0.1); color: #ba1a1a; font-size: 22rpx; font-weight: bold; padding: 4rpx 16rpx; border-radius: 8rpx;">零和已冻结</view>
    </view>

    <!-- All Historical Participants Section -->
    <view class="participant-list card" style="border-top: 4rpx solid #ba1a1a;">
      <view wx:for="{{participants}}" wx:key="id" class="participant-row">
        <view class="person">
          <view class="avatar-wrap">
            <view class="avatar" style="background: #efeeeb; color: #6f7976;">{{item.initial}}</view>
          </view>
          <view>
            <view class="person-name">{{item.name}}</view>
            <view class="person-role" style="color: #6f7976;">最终分值</view>
          </view>
        </view>
        <view class="score {{item.scoreTone}}">{{item.score}}</view>
      </view>
    </view>

    <!-- Share settlement result card -->
    <button class="button-primary score-entry" open-type="share" style="background: #1f695d; box-shadow: 0 12rpx 34rpx rgba(31, 105, 93, 0.16);">
      分享结算卡片
    </button>
  </block>

  <!-- Score Transfers List Section -->
  <view class="history-head">
    <view class="section-label">计分明细</view>
    <text class="iconfont history-header-icon">{{icons.history}}</text>
  </view>

  <view class="transfer-list">
    <view wx:for="{{transfers}}" wx:key="id" class="transfer-card">
      <text class="iconfont transfer-icon">{{item.iconCode}}</text>
      <view class="transfer-main">
        <view class="transfer-text">
          <block wx:for="{{item.parsedParts}}" wx:key="index" wx:for-item="part">
            <text wx:if="{{part.type === 'name'}}" class="transfer-name-bold">{{part.text}}</text>
            <text wx:elif="{{part.type === 'value'}}" class="transfer-value-highlight">{{part.text}}</text>
            <text wx:else>{{part.text}}</text>
          </block>
        </view>
        <view class="transfer-meta" style="display: flex; align-items: center; justify-content: space-between; margin-top: 8rpx;">
          <view class="transfer-time" style="margin-top: 0;">{{item.time}}</view>
          <view wx:if="{{game.status === 'active' && !item.reversedAt && item.transferKind !== 'reversal' && item.canReverse}}" 
                class="reverse-action-btn" 
                style="padding: 10rpx 20rpx; margin-right: -10rpx;"
                bindtap="onReverseTransfer" 
                data-transfer-id="{{item.id}}">
            <text class="iconfont" style="color: var(--text-muted); font-size: 28rpx; opacity: 0.6;">{{icons.undo}}</text>
          </view>
        </view>
      </view>
    </view>
    <view wx:if="{{transfers.length === 0}}" style="text-align: center; color: var(--text-muted); font-size: 26rpx; padding: 40rpx;">
      暂无计分记录
    </view>
  </view>

  <!-- Bottom Actions Fixed Block -->
  <view class="bottom-actions">
    <!-- Active only finish button -->
    <button wx:if="{{game.status === 'active'}}" class="finish-button" bindtap="finish" hover-class="tap-feedback">
      <text class="iconfont button-icon">{{icons.flag}}</text>
      结束本局
    </button>

    <!-- Bottom navigation tabs -->
    <view class="bottom-nav">
      <button bindtap="backHome">
        <text class="iconfont">{{icons.home}}</text>
        <text class="nav-label">首页</text>
      </button>
      <button class="active">
        <text class="iconfont">{{icons.chart}}</text>
        <text class="nav-label">牌局</text>
      </button>
      <button bindtap="ranking">
        <text class="iconfont">{{icons.history}}</text>
        <text class="nav-label">历史</text>
      </button>
    </view>
  </view>

  <!-- Glassmorphic Invite QR Overlay -->
  <view wx:if="{{showInviteOverlay}}" class="invite-overlay" bindtap="hideInvite">
    <view class="invite-popup" catchtap="none">
      <view class="invite-popup-title">微信扫码加入</view>
      <view wx:if="{{isLoadingJoinCode}}" style="width: 360rpx; height: 360rpx; display: flex; align-items: center; justify-content: center; color: var(--text-muted);">
        正在生成小程序码...
      </view>
      <image wx:else class="qr-image" src="{{qrCodeUrl}}" mode="aspectFit"></image>
      <view class="invite-popup-hint">用微信扫一扫上方小程序码可直接进入加入页</view>
      <button class="invite-close-btn" bindtap="hideInvite" hover-class="tap-feedback">关闭</button>
    </view>
  </view>
</view>
