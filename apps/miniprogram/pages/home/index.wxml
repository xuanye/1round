<view class="page home-page">
  <view class="topbar">
    <view class="brand">
      <text class="icon icon-playing_cards brand-icon"></text>
      <view class="brand-name">一局一分</view>
    </view>
    <button class="icon-button" hover-class="tap-feedback">
      <text class="icon icon-settings"></text>
    </button>
  </view>

  <view class="greeting">
    <view>
      <view class="hello">你好，{{userName}}</view>
      <view class="hello-copy">准备好和家人们来一场愉快的博弈了吗？</view>
    </view>
    <view class="greeting-art-img">
      <image class="greeting-img" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBAkvv38dg-wZ89Iu3xQpEiqAJ08JV61P_7jHKbZgEYnP05ObnGNU-BK6QD-dfFH9dRe4fnSI2H0_MbCh39XVmI6CbU_LlRkrCpUJMOq2mmQVuY6ZMpax-tOX1UFCvRusuapCGrBB4aJ9uUFM2jYiF58MQwR61VI1e7gzBm1wOb4_XZSiM5i7MiV3ldz0Bvefq5kXsq1ULzPQQCYNXZfrd3NZyw0_M4Ppv0yrnQdE5mcYjeQImVZ7LsvQ" mode="aspectFit"></image>
    </view>
  </view>

  <view class="current-card card">
    <view class="current-head">
      <view>
        <view class="game-title-row">
          <view class="live-dot animate-pulse"></view>
          <view class="game-title">{{currentGame.name}}</view>
        </view>
        <view class="game-meta">{{currentGame.date}} · {{currentGame.participantCount}}人参与</view>
      </view>
      <view class="my-score">
        <view class="score-label">当前个人分值</view>
        <view class="score-value">+{{currentGame.myScore}}</view>
      </view>
    </view>
    <button class="button-primary enter-button" hover-class="tap-feedback" bindtap="enterGame">
      <text class="icon icon-login button-icon"></text>
      进入牌局
    </button>
    <button class="exit-button disabled" hover-class="tap-feedback" bindtap="showExitTip">
      <text class="icon icon-logout button-icon"></text>
      退出牌局
    </button>
    <view class="exit-tip">分值清零后可退出</view>
  </view>

  <view class="actions">
    <button class="create-disabled" disabled>
      <text class="icon icon-add_circle button-icon"></text>
      已在牌局中
    </button>
    <view class="action-grid">
      <button class="action-card" hover-class="tap-feedback" bindtap="joinGame">
        <text class="icon icon-group_add action-icon"></text>
        <view>加入牌局</view>
      </button>
      <button class="action-card" hover-class="tap-feedback" bindtap="history">
        <text class="icon icon-history action-icon"></text>
        <view>历史记录</view>
      </button>
    </view>
  </view>

  <view class="overview">
    <view class="section-title">本月概览</view>
    <view class="stat-grid">
      <view wx:for="{{stats}}" wx:key="label" class="stat-card card {{item.tone}}">
        <view class="stat-top">
          <view>{{item.label}}</view>
          <text class="icon icon-{{item.icon}} stat-icon"></text>
        </view>
        <view class="stat-number">{{item.value}}<text>{{item.unit}}</text></view>
      </view>
    </view>
  </view>

  <view class="recent-section">
    <view class="section-head">
      <view class="section-title">最近牌局</view>
      <button bindtap="history" hover-class="tap-feedback">查看全部</button>
    </view>
    <view class="recent-list">
      <view wx:for="{{recentGames}}" wx:key="title" class="recent-card card" hover-class="tap-feedback">
        <text class="icon icon-{{item.icon}} recent-icon"></text>
        <view class="recent-main">
          <view class="recent-row">
            <view class="recent-title">{{item.title}}</view>
            <view class="recent-status">{{item.status}}</view>
          </view>
          <view class="recent-meta">{{item.meta}}</view>
        </view>
        <view class="recent-score">
          <view>胜者</view>
          <text>{{item.score}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-nav">
    <button class="nav-item active">
      <text class="icon icon-home"></text>
      <text>首页</text>
    </button>
    <button class="nav-item" bindtap="enterGame">
      <text class="icon icon-leaderboard"></text>
      <text>数据</text>
    </button>
    <button class="nav-item" bindtap="history">
      <text class="icon icon-history"></text>
      <text>历史</text>
    </button>
  </view>
</view>
