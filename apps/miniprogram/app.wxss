page {
  background: #faf9f6;
  color: #1a1c1a;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 32rpx 40rpx 56rpx;
  box-sizing: border-box;
}

.button-primary {
  background: linear-gradient(180deg, #1f695d 0%, #15564c 100%);
  color: #ffffff;
  border-radius: 999rpx;
  font-weight: 700;
  box-shadow: 0 18rpx 38rpx rgba(31, 105, 93, 0.18);
  transition: transform 180ms ease, opacity 180ms ease, box-shadow 180ms ease;
}

.muted {
  color: #3f4946;
}

button {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  line-height: normal;
  transition: transform 180ms ease, opacity 180ms ease;
}

button::after {
  border: 0;
}

.card {
  background: #ffffff;
  border: 1rpx solid rgba(190, 201, 197, 0.45);
  border-radius: 32rpx;
  box-shadow: 0 12rpx 44rpx rgba(31, 105, 93, 0.08);
}

.soft-card {
  background: #ffffff;
  border: 1rpx solid rgba(190, 201, 197, 0.38);
  border-radius: 32rpx;
  box-shadow: 0 12rpx 38rpx rgba(31, 105, 93, 0.07);
}

.tap-feedback {
  opacity: 0.86;
  transform: scale(0.985);
}

/* Material Symbols Outlined Icon Font */
.material-symbols-outlined {
  font-family: 'Material Symbols Outlined' !important;
  font-weight: normal;
  font-style: normal;
  font-size: 48rpx; /* Default size for mini program */
  line-height: 1;
  letter-spacing: normal;
  text-transform: none;
  display: inline-block;
  white-space: nowrap;
  word-wrap: normal;
  direction: ltr;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering: optimizeLegibility;
  font-feature-settings: 'liga';
}

/* Pulse Animation for Live Dot */
@keyframes pulse {
  0% {
    transform: scale(0.92);
    opacity: 0.6;
  }
  50% {
    transform: scale(1.1);
    opacity: 1;
  }
  100% {
    transform: scale(0.92);
    opacity: 0.6;
  }
}

.animate-pulse {
  animation: pulse 2s infinite ease-in-out;
}

/* Tertiary color helpers */
.text-tertiary {
  color: #8e4e14;
}

.bg-tertiary-container-light {
  background: rgba(142, 78, 20, 0.1);
}

