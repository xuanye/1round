.home-page {
  padding-bottom: 156rpx;
}

.topbar,
.brand,
.greeting,
.current-head,
.game-title-row,
.action-grid,
.stat-grid,
.section-head,
.recent-card,
.recent-row,
.bottom-nav,
.nav-item {
  display: flex;
}

.topbar {
  align-items: center;
  justify-content: space-between;
  min-height: 80rpx;
}

.brand {
  align-items: center;
  flex: 1;
  min-width: 0;
}

.brand-icon {
  width: 52rpx;
  height: 52rpx;
  margin-right: 14rpx;
  font-size: 48rpx !important;
  line-height: 52rpx;
  text-align: center;
  color: #1f695d;
}

.brand-name {
  min-width: 0;
  color: #1f695d;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.15;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.greeting {
  align-items: center;
  justify-content: space-between;
  margin-top: 28rpx;
  padding: 40rpx;
  border-radius: 32rpx;
  background: rgba(91, 160, 146, 0.1);
}

.greeting > view:first-child {
  flex: 1;
  min-width: 0;
  margin-right: 28rpx;
}

.hello {
  color: #1f695d;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.22;
}

.hello-copy {
  margin-top: 12rpx;
  color: #3f4946;
  font-size: 28rpx;
  line-height: 1.55;
}

.greeting-art-img {
  width: 192rpx;
  height: 192rpx;
  flex: 0 0 192rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.greeting-img {
  width: 100%;
  height: 100%;
}

.current-card {
  margin-top: 32rpx;
  padding: 32rpx;
}

.current-head {
  align-items: flex-start;
  justify-content: space-between;
}

.current-head > view:first-child {
  flex: 1;
  min-width: 0;
  margin-right: 24rpx;
}

.game-title-row {
  align-items: center;
}

.live-dot {
  margin-right: 12rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #1f695d;
}

.game-title {
  min-width: 0;
  color: #1a1c1a;
  font-size: 30rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.game-meta,
.score-label,
.exit-tip,
.recent-meta,
.recent-status,
.recent-score {
  color: #3f4946;
  font-size: 22rpx;
}

.game-meta {
  margin-top: 10rpx;
}

.my-score {
  flex: 0 0 190rpx;
  text-align: right;
}

.score-value {
  margin-top: 4rpx;
  color: #1f695d;
  font-size: 44rpx;
  font-weight: 900;
}

.enter-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  margin-top: 30rpx;
  font-size: 30rpx;
  line-height: 1;
}

.exit-button {
  width: 100%;
  height: 48rpx;
  margin-top: 22rpx;
  color: rgba(63, 73, 70, 0.42);
  background: transparent;
  font-size: 24rpx;
  line-height: 1;
}

.exit-tip {
  color: rgba(186, 26, 26, 0.72);
  font-size: 20rpx;
  text-align: center;
  margin-top: 6rpx;
}

.enter-button,
.exit-button,
.create-disabled {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.button-icon {
  margin-right: 12rpx;
  font-size: 38rpx !important;
  line-height: 1;
}

.actions {
  margin-top: 28rpx;
}

.action-stack {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.create-disabled {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 86rpx;
  color: rgba(63, 73, 70, 0.5);
  background: #e3e2e0;
  font-size: 28rpx;
  line-height: 1;
}

.scan-button,
.create-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 86rpx;
  font-size: 28rpx;
  line-height: 1;
}

.secondary-action {
  color: #1f695d;
  background: rgba(31, 105, 93, 0.1);
  box-shadow: none;
}

.empty-subtext {
  color: #6f7976;
  font-size: 24rpx;
  text-align: center;
}

.action-grid,
.stat-grid {
  margin-top: 24rpx;
}

button.action-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  width: auto;
  min-height: 148rpx;
  color: #1f695d;
  background: #f4f3f1;
  border-radius: 32rpx;
  font-size: 28rpx;
  line-height: 1.25;
}

button.action-card + button.action-card,
.stat-card + .stat-card {
  margin-left: 24rpx;
}

.action-icon {
  margin-bottom: 12rpx;
  font-size: 40rpx;
  font-weight: 900;
}

.overview,
.recent-section {
  margin-top: 42rpx;
}

.section-title {
  color: #3f4946;
  font-size: 26rpx;
  font-weight: 800;
}

.stat-card {
  flex: 1;
  height: 184rpx;
  padding: 28rpx;
  box-sizing: border-box;
}

.stat-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  color: #3f4946;
  font-size: 22rpx;
  font-weight: 700;
}

.stat-top > view {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stat-icon {
  width: 42rpx;
  height: 42rpx;
  border-radius: 14rpx;
  line-height: 42rpx;
  text-align: center;
}

.stat-card.primary .stat-icon { color: #1f695d; background: rgba(31, 105, 93, 0.1); }
.stat-card.tertiary .stat-icon { color: #8e4e14; background: rgba(142, 78, 20, 0.1); }

.stat-number {
  margin-top: 34rpx;
  color: #1f695d;
  font-size: 48rpx;
  font-weight: 900;
}

.stat-card.tertiary .stat-number {
  color: #8e4e14;
}

.stat-number text {
  margin-left: 6rpx;
  color: #3f4946;
  font-size: 22rpx;
}

.section-head {
  align-items: center;
  justify-content: space-between;
}

.section-head .more-btn {
  color: #1f695d;
  font-size: 24rpx;
  font-weight: 500;
  padding: 10rpx 0 10rpx 20rpx;
}

.recent-list {
  display: flex;
  flex-direction: column;
  margin-top: 22rpx;
}

.recent-card {
  align-items: center;
  padding: 28rpx;
}

.recent-card + .recent-card {
  margin-top: 22rpx;
}

.recent-icon,
.recent-main {
  margin-right: 24rpx;
}

.recent-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  color: #3f4946;
  background: #e3e2e0;
  font-size: 40rpx !important;
  line-height: 88rpx;
  text-align: center;
  display: block;
}

.recent-main {
  flex: 1;
  min-width: 0;
}

.recent-row {
  align-items: flex-start;
  justify-content: space-between;
}

.recent-title {
  flex: 1;
  min-width: 0;
  margin-right: 16rpx;
  color: #1a1c1a;
  font-size: 28rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recent-status,
.recent-score {
  flex-shrink: 0;
}

.recent-meta {
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recent-score {
  text-align: right;
}

.recent-score text {
  display: block;
  margin-top: 6rpx;
  color: #1a1c1a;
  font-size: 26rpx;
  font-weight: 900;
}

.bottom-nav {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 10;
  justify-content: space-around;
  padding: 14rpx 36rpx 34rpx;
  border-top: 1rpx solid rgba(190, 201, 197, 0.3);
  border-radius: 32rpx 32rpx 0 0;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 -8rpx 28rpx rgba(31, 105, 93, 0.08);
}

.nav-item {
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 132rpx;
  height: 82rpx;
  color: #3f4946;
  background: transparent;
  font-size: 34rpx;
  line-height: 1;
}

.nav-item .nav-label {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.15;
}

.nav-item.active {
  color: #1f695d;
  background: transparent;
  font-weight: bold;
}

.nav-item .iconfont {
  font-size: 44rpx !important;
  line-height: 44rpx;
}
