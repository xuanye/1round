<view class="page join-page">
  <view class="join-ambient join-ambient-one"></view>
  <view class="join-ambient join-ambient-two"></view>

  <view class="join-topbar">
    <view class="join-brand">
      <text class="iconfont join-brand-icon">{{icons.dice}}</text>
      <view>OneRound</view>
    </view>
    <button class="close-button" bindtap="cancel" hover-class="tap-feedback">
      <text class="iconfont">{{icons.close}}</text>
    </button>
  </view>

  <view class="join-title">
    <view>加入牌局</view>
    <text>确认信息并设置您的显示名称</text>
  </view>

  <view class="join-card card">
    <view class="game-info">
      <view>
        <view class="field-label">牌局名称</view>
        <view class="game-name">{{game.name}}</view>
      </view>
      <text class="iconfont game-icon">{{icons.users}}</text>
    </view>

    <view class="creator-row">
      <image class="creator-avatar-img" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA4aBZKAnfl02gutJ01dL6tH7kiV3du8B8dOTtfnrectac-a4xx1rGL2bvvbWv_xsv5EzC_mCo-HhlCQe3SFTIbpBvJC7dgt725aOPQmJ3UkoMaalv1iFlP1hllCl-1WFPNbuSJF9ghIERbAStaRm_4l9WiZo401l_nbTlMu-8nR24at39Kuck_mBEHgoq_jDv5hdR43Qn7S_n9Pl2XkSdzBnjUsANX1GFDzOR-3ugRxMaGTcF7kvMM2w" mode="aspectFill"></image>
      <view>
        <view class="field-label">创建者</view>
        <view class="creator-name">{{game.creatorName}}</view>
      </view>
    </view>

    <view class="divider"></view>

    <view class="participant-head">
      <view>当前参与者</view>
      <text>{{game.participantText}}</text>
    </view>
    <view class="avatar-stack">
      <block wx:for="{{participants}}" wx:key="id">
        <image wx:if="{{item.avatarUrl}}" class="stack-avatar" src="{{item.avatarUrl}}" mode="aspectFill"></image>
        <view wx:else class="stack-avatar text-avatar">{{item.initial}}</view>
      </block>
    </view>

    <view class="name-block">
      <view class="field-label">我的显示名称</view>
      <view class="input-shell">
        <input value="{{displayName}}" bindinput="onNameInput" maxlength="12" />
        <text class="iconfont edit-icon">{{icons.edit}}</text>
      </view>
      <view class="name-tip">
        <text class="iconfont info-icon">{{icons.info}}</text>
        名称在牌局内必须唯一
      </view>
    </view>
  </view>

  <view class="join-actions">
    <button
      class="button-primary join-submit {{joined ? 'joined' : ''}}"
      bindtap="submit"
      hover-class="tap-feedback"
      disabled="{{joining || joined}}"
    >
      <block wx:if="{{joining}}">正在加入...</block>
      <block wx:elif="{{joined}}">
        <text class="iconfont button-icon">{{icons.check}}</text> 已成功加入
      </block>
      <block wx:else>
        确认加入
        <text class="iconfont button-icon">{{icons.arrowRight}}</text>
      </block>
    </button>
    <button class="cancel-button" bindtap="cancel" hover-class="tap-feedback">取消</button>
  </view>
</view>
