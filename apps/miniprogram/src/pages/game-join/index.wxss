.join-page {
  position: relative;
  overflow: hidden;
  padding-bottom: 80rpx;
}

.join-ambient {
  position: fixed;
  z-index: 0;
  border-radius: 50%;
  opacity: 0.42;
}

.join-ambient-one {
  top: -120rpx;
  right: -120rpx;
  width: 360rpx;
  height: 360rpx;
  background: #a9f0e0;
}

.join-ambient-two {
  bottom: -120rpx;
  left: -120rpx;
  width: 320rpx;
  height: 320rpx;
  background: #bfe9ff;
}

.join-topbar,
.join-title,
.join-card,
.join-actions,
.join-brand,
.game-info,
.creator-row,
.participant-head,
.avatar-stack {
  display: flex;
}

.join-topbar,
.join-title,
.join-card,
.join-actions {
  position: relative;
  z-index: 1;
}

.join-topbar {
  align-items: center;
  justify-content: space-between;
  min-height: 80rpx;
}

.join-brand {
  align-items: center;
  color: #1f695d;
  font-size: 32rpx;
  font-weight: 900;
  min-width: 0;
}

.join-brand-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 14rpx;
  font-size: 44rpx !important;
  line-height: 48rpx;
  color: #1f695d;
}

.close-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  color: #3f4946;
  background: #f4f3f1;
}

.close-button .iconfont {
  font-size: 36rpx !important;
}

.join-title {
  display: block;
  margin-top: 64rpx;
  text-align: center;
}

.join-title view {
  color: #1a1c1a;
  font-size: 52rpx;
  font-weight: 900;
}

.join-title text {
  display: block;
  margin-top: 14rpx;
  color: #3f4946;
  font-size: 28rpx;
}

.join-card {
  margin-top: 46rpx;
  padding: 40rpx;
  background: rgba(255, 255, 255, 0.84);
}

.game-info {
  align-items: flex-start;
  justify-content: space-between;
}

.game-info > view:first-child {
  flex: 1;
  min-width: 0;
  margin-right: 24rpx;
}

.field-label {
  color: #1f695d;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
}

.game-name {
  margin-top: 10rpx;
  color: #1a1c1a;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.game-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  color: #1f695d;
  background: rgba(91, 160, 146, 0.18);
  font-size: 38rpx !important;
  line-height: 64rpx;
  text-align: center;
  display: block;
}

.creator-row {
  align-items: center;
  margin-top: 28rpx;
}

.creator-avatar {
  margin-right: 18rpx;
}

.creator-avatar-img {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex: 0 0 64rpx;
}

.creator-avatar-img.text-avatar {
  background: #1f695d;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.creator-name {
  color: #1a1c1a;
  font-size: 28rpx;
  font-weight: 900;
}

.divider {
  height: 1rpx;
  margin: 34rpx 0;
  background: rgba(190, 201, 197, 0.45);
}

.participant-head {
  align-items: center;
  justify-content: space-between;
  color: #3f4946;
  font-size: 26rpx;
  font-weight: 800;
}

.participant-head text {
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  color: #1f695d;
  background: rgba(31, 105, 93, 0.1);
}

.avatar-stack {
  margin-top: 18rpx;
  padding-left: 12rpx;
}

.stack-avatar {
  width: 72rpx;
  height: 72rpx;
  margin-left: -12rpx;
  border: 4rpx solid #faf9f6;
  border-radius: 50%;
  box-shadow: 0 8rpx 24rpx rgba(31, 105, 93, 0.1);
  box-sizing: border-box;
  flex-shrink: 0;
}

.stack-avatar.text-avatar {
  color: #3f4946;
  background: #e3e2e0;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 64rpx;
  text-align: center;
}

.name-block {
  margin-top: 38rpx;
}

.input-shell {
  display: flex;
  align-items: center;
  height: 108rpx;
  margin-top: 14rpx;
  padding: 0 28rpx;
  border: 2rpx solid transparent;
  border-radius: 24rpx;
  background: rgba(250, 249, 246, 0.8);
  box-shadow: inset 0 2rpx 8rpx rgba(31, 105, 93, 0.06);
}

.input-shell input {
  flex: 1;
  min-width: 0;
  height: 100%;
  color: #1a1c1a;
  font-size: 34rpx;
  font-weight: 700;
}

.input-shell .edit-icon {
  color: #3f4946;
  font-size: 38rpx !important;
}

.name-tip {
  margin-top: 12rpx;
  color: #3f4946;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  line-height: 1.35;
}

.name-tip .info-icon {
  margin-right: 8rpx;
  font-size: 26rpx !important;
  color: #3f4946;
}

.join-actions {
  margin-top: 40rpx;
}

.join-submit {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 104rpx;
  font-size: 30rpx;
  line-height: 1;
  gap: 12rpx;
}

.join-submit .button-icon {
  font-size: 36rpx !important;
}

.join-submit.joined {
  background: #1f695d;
}

.cancel-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 72rpx;
  margin-top: 20rpx;
  color: #3f4946;
  background: transparent;
  font-size: 28rpx;
}
