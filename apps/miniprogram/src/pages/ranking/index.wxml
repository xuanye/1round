<view class="page">
  <view class="tabs">
    <view class="tab active">排行榜</view>
    <view class="tab">历史牌局</view>
  </view>

  <view class="rank-card card">
    <view class="rank-title">总分排行榜</view>
    <view class="rank-head">
      <text>排名</text>
      <text>玩家</text>
      <text>总分</text>
      <text>平均分/局</text>
    </view>
    <view wx:for="{{players}}" wx:key="playerId" class="rank-row">
      <view class="medal medal-{{index}}">{{index + 1}}</view>
      <view class="player-cell">
        <view class="avatar">{{item.initial}}</view>
        <text>{{item.displayName}}</text>
      </view>
      <text class="{{item.scoreTone}}">{{item.scoreLabel}}</text>
      <text>{{item.averageLabel}}</text>
    </view>
  </view>

  <view class="history-card card">
    <view class="history-head">
      <text>历史牌局</text>
      <text class="muted history-link" bindtap="openHistory">查看全部 ›</text>
    </view>
    <view wx:if="{{historyItems.length === 0}}" class="history-empty">暂无历史牌局</view>
    <view wx:for="{{historyItems}}" wx:key="id" class="history-row" data-id="{{item.id}}" bindtap="openDetail">
      <view class="calendar {{item.accentTone}}"></view>
      <view class="history-main">
        <view class="history-name">{{item.name}}</view>
        <view class="history-meta">{{item.meta}}</view>
      </view>
      <text class="status ended">已结束</text>
    </view>
  </view>
</view>
